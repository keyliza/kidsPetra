# ─────────────────────────────────────────────────────────
#  Petra Kids — variables de entorno
#  Copia este archivo a «.env» y ajusta los valores.
# ─────────────────────────────────────────────────────────

# --- Base de datos (SQL Server) ---
# Contraseña del usuario 'sa'. Debe ser fuerte: 8+ caracteres con mayúsculas,
# minúsculas, números y símbolos (requisito de SQL Server).
SA_PASSWORD=Cambia_Esta_Clave_123!
DB_NAME=PetraKids
# Edición de SQL Server: Developer (gratis, no producción) o Express.
MSSQL_PID=Developer

# --- Seguridad JWT ---
# Secreto para firmar los tokens. MÍNIMO 32 caracteres. Genera uno aleatorio, p.ej.:
#   openssl rand -base64 48
JWT_SECRET=pon-aqui-un-secreto-largo-y-aleatorio-de-32-caracteres-o-mas
JWT_ISSUER=petra-kids
JWT_AUDIENCE=petra-kids
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# --- Usuario administrador inicial (creado por el seed) ---
ADMIN_EMAIL=admin@petramatagalpa.com
ADMIN_PASSWORD=Cambia_Esta_Clave_Admin_123!

# --- CORS ---
# Solo necesario si el frontend se sirve en un dominio distinto al de la API.
# Con el proxy de Nginx (mismo dominio) puedes dejar el valor por defecto.
CORS_ORIGINS=https://petrakids.petramatagalpa.com

# --- Frontend ---
# Puerto del host al que se mapea el contenedor del frontend (Dokploy suele
# gestionar el dominio/SSL por encima de este puerto).
FRONTEND_PORT=8080
